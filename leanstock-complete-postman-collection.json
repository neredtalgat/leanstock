      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@demo.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"Admin@123456\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "  pm.environment.set('accessToken', jsonData.accessToken);",
                  "  pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "  if (jsonData.user && jsonData.user.id) {",
                  "    pm.environment.set('userId', jsonData.user.id);",
                  "  }",
                  "}",
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has access token', function () { pm.expect(jsonData).to.have.property('accessToken'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/refresh",
