# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://leanstock:password@localhost:5432/leanstock

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-secret-key-min-32-characters-long-please
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Email Service (SMTP)
# For Gmail: Enable 2FA and use App Password (not your regular password)
# For SendGrid: Use API key as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@leanstock.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Email Token Expiry
EMAIL_VERIFICATION_EXPIRES_IN=24h
PASSWORD_RESET_EXPIRES_IN=1h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Background Jobs
BULLMQ_REDIS_URL=redis://localhost:6379
INVENTORY_CHECK_CRON=0 */30 * * * *
DEAD_STOCK_CHECK_CRON=0 0 2 * * *

# Security
SESSION_SECRET=your-session-secret-min-32-chars
API_RATE_LIMIT=100

# Business Logic
TRANSFER_APPROVAL_THRESHOLD=1000

# Development
ENABLE_SWAGGER=true
ENABLE_LOG_SQL=false
