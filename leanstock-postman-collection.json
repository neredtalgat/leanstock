              "raw": "{\n  \"sku\": \"SKU-NEW-001\",\n  \"name\": \"New Product\",\n  \"description\": \"A new test product\",\n  \"baseCost\": 25.00,\n  \"retailPrice\": 39.99,\n  \"weight\": 1.0\n}"
            }
          }
        },
        {
