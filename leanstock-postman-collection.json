{
  "info": {
    "name": "LeanStock API (Complete)",
    "description": "Complete Postman collection with all available LeanStock API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "leanstock-complete-api"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant.admin@leanstock.local\",\n  \"password\": \"AdminPass123!\",\n  \"firstName\": \"Tenant\",\n  \"lastName\": \"Admin\",\n  \"role\": \"TENANT_ADMIN\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant.admin@leanstock.local\",\n  \"password\": \"AdminPass123!\",\n  \"tenantId\": \"{{tenantId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.accessToken) pm.environment.set('accessToken', jsonData.accessToken);",
                  "if (jsonData.refreshToken) pm.environment.set('refreshToken', jsonData.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tenants (SUPER_ADMIN)",
      "item": [
        {
          "name": "POST /tenants",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{superAdminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/tenants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Tenant Co\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.id) pm.environment.set('tenantId', jsonData.id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "GET /products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/products?limit=20"
          }
        },
        {
          "name": "POST /products",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"SKU-NEW-001\",\n  \"name\": \"New Product\",\n  \"description\": \"Created from Postman\",\n  \"baseCost\": 10.5,\n  \"retailPrice\": 15.9,\n  \"weight\": 0.5\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "GET /inventory",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/inventory"
          }
        },
        {
          "name": "POST /inventory/adjust",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/inventory/adjust",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"locationId\": \"{{locationId}}\",\n  \"quantity\": 5,\n  \"operation\": \"ADD\",\n  \"reason\": \"postman adjustment\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "System / Analytics (SUPER_ADMIN)",
      "item": [
        {
          "name": "GET /system/status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/system/status"
          }
        },
        {
          "name": "GET /analytics/cross-tenant",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{superAdminAccessToken}}" }
            ],
            "url": "{{baseUrl}}/analytics/cross-tenant"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "tenantId", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "superAdminAccessToken", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "locationId", "value": "", "type": "string" }
  ]
}
