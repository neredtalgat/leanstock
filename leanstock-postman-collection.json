      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "7c0212ab-cce3-482d-8660-dc92d43030e9",
      "type": "string"
    },
    {
      "key": "locationId1",
      "value": "6b36555a-b372-4638-b4cb-1d2fe9a1aafb",
      "type": "string"
