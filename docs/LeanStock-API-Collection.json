        {
          "name": "Create Purchase Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.environment.set(\"purchaseOrderId\", jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierId\": \"{{supplierId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 100,\n      \"unitPrice\": 25.99\n    }\n  ],\n  \"expectedDeliveryDate\": \"2026-05-15T00:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/purchase-orders",
              "host": ["{{baseUrl}}"],
              "path": ["purchase-orders"]
            },
            "description": "Create purchase order (requires purchase-orders:create permission)"
          },
          "response": []
        },
        {
          "name": "Update Purchase Order Status",
          "request": {
            "method": "PUT",
