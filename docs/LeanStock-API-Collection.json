            },
            "url": {
              "raw": "{{baseUrl}}/purchase-orders/{{purchaseOrderId}}/receive",
              "host": ["{{baseUrl}}"],
              "path": ["purchase-orders", "{{purchaseOrderId}}", "receive"]
            },
            "description": "Receive items from PO (requires purchase-orders:receive permission)"
